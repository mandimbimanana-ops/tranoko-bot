    v('emetteur-preview').innerHTML = `
      <b>${proSession.nom}</b> · ${proSession.tel}<br>
      <span style="color:#888;font-size:0.72rem;">Formule ${proSession.plan === 'annuel' ? 'Annuelle' : 'Mensuelle'} · Valide jusqu'au ${new Date(proSession.expiry).toLocaleDateString('fr-MG')}</span>`;
  }
  v('modal-client').classList.add('open');
}

function closeClientModal() { v('modal-client').classList.remove('open'); }

function confirmerImpressionPro() {
  const nomClient = v('client-nom').value.trim() || 'Client';
  const telClient = v('client-tel').value.trim();
  const objet = v('client-objet').value.trim();
  const devisNum = nextDevisNum();
