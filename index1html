<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tranoko — Devis BTP Madagascar</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=Space+Mono:wght@400;700&family=Noto+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   TRANOKO — DESIGN SYSTEM
═══════════════════════════════════════════════════════ */
:root {
  --or: #F47920;
  --or-fonce: #C85F10;
  --or-pale: #FFF3E8;
  --or-pale2: #FFE0C0;
  --noir: #151515;
  --gris-fonce: #252525;
  --gris-mid: #444;
  --gris: #888;
  --gris-clair: #E5E5E5;
  --fond: #F8F6F2;
  --blanc: #FFFFFF;
  --vert: #2D9945;
  --vert-pale: #E8F5EC;
  --bleu: #1A56A0;
  --rouge: #C0392B;
  --violet: #7B1FA2;
  --violet-pale: #F3E5F5;
  --jaune: #F9A825;
  --ombre: 0 2px 16px rgba(0,0,0,0.08);
  --ombre-md: 0 4px 28px rgba(0,0,0,0.13);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Noto Sans',sans-serif;background:var(--fond);color:var(--noir);line-height:1.5;}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--gris-clair);}
::-webkit-scrollbar-thumb{background:var(--or);border-radius:3px;}

/* ── STICKY HEADER ── */
#hdr {
  position:sticky;top:0;z-index:900;
  background:var(--noir);
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 24px;gap:12px;
  box-shadow:0 2px 20px rgba(0,0,0,0.5);
}
.hdr-brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
.hdr-brand-name{font-family:'Sora',sans-serif;font-size:1.05rem;font-weight:800;color:#FFF;letter-spacing:0.02em;}
.hdr-brand-name span{color:var(--or);}
.hdr-center{display:flex;flex-direction:column;align-items:center;}
.hdr-total-label{font-size:0.6rem;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.45);}
.hdr-total{font-family:'Space Mono',monospace;font-size:1.25rem;font-weight:700;color:var(--or);transition:all 0.3s;cursor:default;}
.hdr-total.bump{transform:scale(1.08);color:#FFB347;}
.hdr-contacts{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.hdr-btn{background:var(--or);color:white;border:none;padding:6px 13px;border-radius:20px;font-size:0.72rem;font-weight:700;cursor:pointer;font-family:'Sora',sans-serif;text-decoration:none;display:inline-flex;align-items:center;gap:5px;transition:background 0.2s;}
.hdr-btn:hover{background:var(--or-fonce);}
.hdr-btn.ghost{background:transparent;border:1.5px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.8);}
.hdr-btn.ghost:hover{border-color:var(--or);color:var(--or);}

/* ── CSV STATUS ── */
.csv-status{font-size:0.68rem;padding:3px 10px;border-radius:100px;font-weight:600;}
.csv-ok{background:#1a3d1a;color:#4CAF50;}
.csv-err{background:#3d1a1a;color:#F44336;}
.csv-loading{background:#2a2a1a;color:var(--jaune);}

/* ── LAYOUT 3 COL ── */
.layout{display:grid;grid-template-columns:155px 1fr 155px;min-height:calc(100vh - 52px);}

/* ── AD COLUMNS ── */
.ad-col{background:#F2EDE4;padding:10px 5px;display:flex;flex-direction:column;gap:9px;border-right:1px solid #DDD5C8;}
.ad-col.right{border-right:none;border-left:1px solid #DDD5C8;}
.ad-pub-label{font-size:0.56rem;text-transform:uppercase;letter-spacing:0.14em;color:#C0B8AE;text-align:center;margin-bottom:2px;}
.ad-slot{background:white;border:1.5px dashed #C8BDB0;border-radius:7px;padding:8px 5px;text-align:center;min-height:100px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;cursor:pointer;transition:border-color 0.2s,box-shadow 0.2s;}
.ad-slot:hover{border-color:var(--or);box-shadow:0 2px 8px rgba(244,121,32,0.15);}
.ad-slot-label{font-size:0.56rem;text-transform:uppercase;letter-spacing:0.1em;color:#B0A898;}
.ad-slot-text{font-size:0.68rem;color:#C0B8AE;line-height:1.4;}
.ad-slot-content{font-size:0.72rem;color:#444;text-align:center;line-height:1.5;}

/* ── MAIN CONTENT ── */
.main{overflow:hidden;padding-bottom:60px;}

/* ── HERO ── */
.hero{
  background:linear-gradient(160deg, var(--noir) 0%, #2A1A08 55%, #1A0D00 100%);
  color:white;padding:36px 36px 28px;position:relative;overflow:hidden;
}
.hero::before{content:'';position:absolute;right:-100px;top:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(244,121,32,0.18) 0%,transparent 65%);pointer-events:none;}
.hero::after{content:'';position:absolute;left:10%;bottom:-60px;width:250px;height:250px;background:radial-gradient(circle,rgba(244,121,32,0.08) 0%,transparent 65%);pointer-events:none;}
.hero-top{display:flex;align-items:flex-start;gap:14px;margin-bottom:16px;}
.hero-logo{width:50px;height:50px;border-radius:50%;border:2px solid var(--or);object-fit:cover;flex-shrink:0;}
.hero-title{font-family:'Sora',sans-serif;font-size:1.8rem;font-weight:800;line-height:1.1;}
.hero-title span{color:var(--or);}
.hero-sub{font-size:0.78rem;opacity:0.6;margin-top:2px;letter-spacing:0.02em;}
.hero-desc{font-size:0.85rem;opacity:0.75;max-width:460px;line-height:1.65;margin-bottom:18px;}
.hero-tabs{display:flex;gap:7px;flex-wrap:wrap;}
.tab-btn{padding:9px 18px;border:1.5px solid rgba(255,255,255,0.3);border-radius:100px;background:transparent;color:rgba(255,255,255,0.85);font-family:'Sora',sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;transition:all 0.2s;letter-spacing:0.01em;}
.tab-btn:hover,.tab-btn.active{background:var(--or);color:white;border-color:var(--or);}

/* ── SECTION BODY ── */
.section-body{padding:24px 32px;}
.panel{display:none;animation:fadeIn 0.25s ease;}
.panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:none;}}

/* ── PANEL TITLE ── */
.ptitle{font-family:'Sora',sans-serif;font-size:1.3rem;font-weight:800;color:var(--or);margin-bottom:2px;}
.psub{font-size:0.8rem;color:var(--gris);margin-bottom:20px;}

/* ── CARDS ── */
.card{background:white;border:1.5px solid #EBEBEB;border-radius:12px;padding:18px;margin-bottom:14px;box-shadow:var(--ombre);}
.card-title{font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:700;display:flex;align-items:center;gap:7px;margin-bottom:14px;padding-bottom:9px;border-bottom:2px solid var(--or-pale);}
.card-title .ico{font-size:1rem;}
.card-title .auto-badge{font-size:0.6rem;background:var(--vert-pale);color:var(--vert);padding:2px 8px;border-radius:100px;font-weight:700;letter-spacing:0.06em;margin-left:4px;}
.card-title .na-badge{font-size:0.6rem;background:#F5F5F5;color:#AAA;padding:2px 8px;border-radius:100px;font-weight:700;letter-spacing:0.06em;margin-left:4px;}

/* ── GRILLES FORM ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:13px;}
.gfull{grid-column:1/-1;}

/* ── FORM ELEMENTS ── */
.fg{display:flex;flex-direction:column;gap:5px;}
.fg label{font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#666;}
.fg label .auto-icon{color:var(--vert);margin-left:3px;font-size:0.8em;cursor:help;}
input[type=number],input[type=text],select,textarea{
  padding:9px 11px;border:1.5px solid #E0D8CC;border-radius:8px;
  font-family:'Noto Sans',sans-serif;font-size:0.88rem;background:white;
  color:var(--noir);transition:border-color 0.2s,box-shadow 0.2s;outline:none;width:100%;
}
input:focus,select:focus{border-color:var(--or);box-shadow:0 0 0 3px rgba(244,121,32,0.12);}
input.auto-field{border-color:#C8E6C9;background:#F9FFF9;}
input.auto-field:focus{border-color:var(--vert);box-shadow:0 0 0 3px rgba(45,153,69,0.1);}
.field-na{background:#F8F8F8;border-color:#EEE;color:#BBB;pointer-events:none;}
.reset-btn{font-size:0.68rem;color:var(--vert);cursor:pointer;text-decoration:underline;margin-top:2px;background:none;border:none;padding:0;font-family:'Noto Sans',sans-serif;}

/* ── STANDING TABS ── */
.standing-row{display:flex;gap:6px;}
.st-btn{flex:1;padding:8px 6px;border:1.5px solid #DDD;border-radius:8px;background:white;font-family:'Sora',sans-serif;font-size:0.75rem;font-weight:700;cursor:pointer;transition:all 0.18s;text-align:center;}
.st-btn.eco.active{background:var(--vert);border-color:var(--vert);color:white;}
.st-btn.std.active{background:var(--or);border-color:var(--or);color:white;}
.st-btn.prem.active{background:var(--violet);border-color:var(--violet);color:white;}
.standing-desc{font-size:0.78rem;color:#555;background:var(--or-pale);border-radius:7px;padding:9px 12px;margin-top:8px;line-height:1.6;border-left:3px solid var(--or);}
.standing-desc.eco-desc{background:var(--vert-pale);border-color:var(--vert);}
.standing-desc.prem-desc{background:var(--violet-pale);border-color:var(--violet);}

/* ── PIÈCES TABLE ── */
.table-wrap{overflow-x:auto;margin-top:8px;}
table.pieces{width:100%;border-collapse:collapse;font-size:0.8rem;}
table.pieces th{background:var(--noir);color:white;padding:8px 10px;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.07em;white-space:nowrap;}
table.pieces td{padding:6px 8px;border-bottom:1px solid #F0EDE8;vertical-align:middle;}
table.pieces tr:nth-child(even) td{background:#FAFAF8;}
table.pieces tr:hover td{background:var(--or-pale);}
table.pieces input,table.pieces select{padding:5px 7px;font-size:0.79rem;border:1.5px solid #E0D8CC;border-radius:6px;background:white;}
table.pieces input{width:60px;}
table.pieces select{width:100%;}
.surf-cell{font-family:'Space Mono',monospace;font-weight:700;color:var(--or);font-size:0.82rem;}
.del-btn{background:#FFF0F0;border:1px solid #FFCDD2;color:var(--rouge);border-radius:5px;padding:3px 8px;cursor:pointer;font-size:0.75rem;transition:all 0.2s;}
.del-btn:hover{background:var(--rouge);color:white;}
.add-btn{background:var(--vert);color:white;border:none;padding:8px 16px;border-radius:8px;cursor:pointer;font-weight:700;font-family:'Sora',sans-serif;font-size:0.78rem;margin-top:8px;transition:opacity 0.2s;display:inline-flex;align-items:center;gap:5px;}
.add-btn:hover{opacity:0.88;}

/* ── TOITURE CHECKBOXES ── */
.toit-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:8px;}
.toit-item{background:var(--fond);border:1.5px solid #E5E0D8;border-radius:9px;padding:11px;transition:border-color 0.2s;}
.toit-item.checked{border-color:var(--or);background:var(--or-pale);}
.toit-item-top{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.toit-item-top input[type=checkbox]{width:16px;height:16px;accent-color:var(--or);cursor:pointer;flex-shrink:0;}
.toit-item-label{font-size:0.82rem;font-weight:600;cursor:pointer;}
.toit-item-sub{font-size:0.7rem;color:var(--gris);margin-bottom:7px;}
.toit-item-fields{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.toit-item-fields .fg label{font-size:0.65rem;}
.toit-item-fields input,
.toit-item-fields select{font-size:0.76rem;padding:5px 7px;}

/* ── CATS GRID (freemium) ── */
.cats-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin:18px 0;}
.cat-card{background:white;border:1.5px solid var(--gris-clair);border-radius:10px;padding:13px 14px;display:flex;justify-content:space-between;align-items:center;transition:border-color 0.2s,box-shadow 0.2s;}
.cat-card:hover{border-color:var(--or);box-shadow:var(--ombre);}
.cat-name{font-weight:600;font-size:0.83rem;}
.cat-sub{font-size:0.68rem;color:#AAA;font-style:italic;margin-top:1px;}
.cat-amt{font-family:'Space Mono',monospace;font-size:0.88rem;color:var(--or);font-weight:700;}
.cat-amt.blurred,.qty-blurred,.sub-blurred{filter:blur(7px);user-select:none;pointer-events:none;transition:filter 0.3s;}
.unlock-hint{font-size:0.7rem;color:var(--gris);text-align:center;margin-top:-8px;margin-bottom:6px;}

/* ── INFOBOX ── */
.infobox{background:var(--or-pale);border-left:3px solid var(--or);border-radius:0 8px 8px 0;padding:10px 14px;font-size:0.82rem;color:#7A3800;margin:12px 0;line-height:1.6;}
.infobox.vert{background:var(--vert-pale);border-color:var(--vert);color:#1A4A22;}
.infobox.bleu{background:#E3F0FF;border-color:var(--bleu);color:#0D3A7A;}

/* ── BTN PAYER ── */
.btn-pay{
  background:linear-gradient(135deg,var(--or) 0%,var(--or-fonce) 100%);
  color:white;border:none;padding:15px 36px;border-radius:100px;
  font-family:'Sora',sans-serif;font-size:0.95rem;font-weight:800;cursor:pointer;
  box-shadow:0 6px 22px rgba(244,121,32,0.38);transition:all 0.22s;
  display:block;margin:22px auto;text-align:center;letter-spacing:0.01em;
}
.btn-pay:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(244,121,32,0.5);}
.btn-pay .note{display:block;font-size:0.68rem;font-weight:400;margin-top:3px;opacity:0.85;}

/* ── RESULT SECTION ── */
.result-wrap{display:none;}
.result-wrap.visible{display:block;animation:fadeIn 0.35s ease;}
.res-header{background:var(--noir);color:white;border-radius:12px;padding:20px 24px;margin:16px 0;display:flex;justify-content:space-between;align-items:center;gap:10px;}
.res-hdr-info{flex:1;}
.res-hdr-label{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;opacity:0.55;}
.res-hdr-sub{font-size:0.75rem;opacity:0.4;margin-top:3px;line-height:1.5;}
.res-hdr-amt{font-family:'Space Mono',monospace;font-size:1.7rem;color:var(--or);font-weight:700;white-space:nowrap;}
.res-print-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.btn-print{background:var(--bleu);color:white;border:none;padding:9px 22px;border-radius:100px;font-weight:700;cursor:pointer;font-size:0.8rem;font-family:'Sora',sans-serif;transition:opacity 0.2s;}
.btn-print:hover{opacity:0.85;}

/* ── RESULT TABLES ── */
.rtitle{font-family:'Sora',sans-serif;font-size:0.98rem;font-weight:700;margin:22px 0 10px;padding-bottom:7px;border-bottom:2px solid var(--gris-clair);display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.rtitle .badge{background:var(--or);color:white;padding:2px 9px;border-radius:100px;font-size:0.66rem;font-weight:700;}
.rtitle .badge-vert{background:var(--vert);color:white;padding:2px 9px;border-radius:100px;font-size:0.66rem;font-weight:700;}
.rtitle .badge-bleur{background:var(--bleu);color:white;padding:2px 9px;border-radius:100px;font-size:0.66rem;font-weight:700;}
table.res{width:100%;border-collapse:collapse;font-size:0.81rem;margin-bottom:16px;}
table.res th{background:var(--noir);color:white;padding:8px 11px;text-align:left;font-size:0.68rem;text-transform:uppercase;letter-spacing:0.07em;}
table.res td{padding:7px 11px;border-bottom:1px solid #F0EDE8;}
table.res tr:nth-child(even) td{background:#FAFAF8;}
table.res tr:hover td{background:var(--or-pale);}
.td-qty{font-family:'Space Mono',monospace;font-size:0.8rem;color:#444;}
.td-pu{font-size:0.78rem;color:var(--gris);}
.td-amt{font-family:'Space Mono',monospace;text-align:right;color:var(--or);font-weight:700;}
.td-dim{font-size:0.72rem;color:var(--gris);}
.td-note{font-size:0.7rem;color:#AAA;font-style:italic;}
.tr-total td{background:var(--or-pale)!important;font-weight:700;}

/* ── BADGE NIVEAU ── */
.nbadge{display:inline-block;padding:3px 9px;border-radius:100px;font-size:0.66rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;}
.nb-rdc{background:#E3F2FD;color:#1565C0;}
.nb-etage{background:#FFF3E0;color:#E65100;}
.nb-terrasse{background:#E8F5E9;color:#2E7D32;}

/* ── MODAL ── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.72);z-index:2000;align-items:center;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:white;border-radius:16px;padding:30px;max-width:500px;width:93%;box-shadow:0 24px 64px rgba(0,0,0,0.35);position:relative;animation:modalIn 0.25s ease;}
@keyframes modalIn{from{opacity:0;transform:scale(0.95) translateY(10px);}to{opacity:1;transform:none;}}
.modal h2{font-family:'Sora',sans-serif;font-size:1.2rem;font-weight:800;margin-bottom:5px;}
.modal-badge{display:inline-block;background:var(--or);color:white;padding:4px 13px;border-radius:100px;font-size:0.8rem;font-weight:700;margin-bottom:12px;}
.modal-close{position:absolute;top:12px;right:15px;background:none;border:none;font-size:1.25rem;cursor:pointer;color:#AAA;transition:color 0.2s;}
.modal-close:hover{color:var(--noir);}
.code-row{display:flex;gap:8px;margin:12px 0;}
.code-row input{flex:1;font-family:'Space Mono',monospace;font-size:1rem;text-align:center;letter-spacing:0.18em;border:2px solid var(--gris-clair);padding:10px;border-radius:9px;}
.btn-val{background:var(--or);color:white;border:none;padding:10px 20px;border-radius:9px;font-weight:700;cursor:pointer;font-family:'Sora',sans-serif;transition:background 0.2s;}
.btn-val:hover{background:var(--or-fonce);}
.code-err{color:var(--rouge);font-size:0.78rem;margin-top:3px;display:none;}
.code-ok{color:var(--vert);font-size:0.78rem;margin-top:3px;display:none;}
.pay-contact{background:var(--or-pale);border-radius:9px;padding:12px;font-size:0.78rem;color:#7A3800;line-height:1.9;margin-top:10px;}
.pay-contact strong{color:var(--or-fonce);}

/* ── ADMIN ── */
.admin-toggle-area{text-align:center;margin:16px 0;}
.btn-admin-tog{background:none;border:1.5px solid var(--gris-clair);padding:7px 17px;border-radius:100px;font-size:0.72rem;color:#AAA;cursor:pointer;transition:all 0.2s;}
.btn-admin-tog:hover{border-color:var(--or);color:var(--or);}
.admin-pass-row{display:flex;gap:8px;justify-content:center;margin:8px 0;}
.admin-panel{background:#0F0F1A;color:white;border-radius:12px;padding:22px;margin:16px 0;}
.admin-panel h3{font-family:'Sora',sans-serif;font-size:1rem;color:var(--or);margin-bottom:4px;}
.admin-panel p.sub{font-size:0.72rem;color:#888;margin-bottom:16px;}
.admin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;}
.admin-item{background:rgba(255,255,255,0.06);border-radius:8px;padding:10px;}
.admin-item label{color:#999;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.06em;display:block;margin-bottom:4px;}
.admin-item input{background:rgba(255,255,255,0.1);color:white;border:1px solid rgba(255,255,255,0.15);padding:5px 9px;border-radius:6px;width:100%;font-size:0.82rem;}
.btn-save{background:var(--or);color:white;border:none;padding:8px 20px;border-radius:8px;font-weight:700;cursor:pointer;margin-top:4px;font-family:'Sora',sans-serif;}
.csv-reload-btn{background:#1A5276;color:white;border:none;padding:8px 18px;border-radius:8px;font-weight:700;cursor:pointer;font-size:0.8rem;font-family:'Sora',sans-serif;margin-right:8px;}
.code-item{display:flex;align-items:center;gap:10px;padding:7px 9px;background:rgba(255,255,255,0.04);border-radius:7px;margin-top:5px;flex-wrap:wrap;}
.code-val{font-family:'Space Mono',monospace;font-size:0.85rem;font-weight:700;color:#EEE;}
.code-st{font-size:0.66rem;padding:2px 8px;border-radius:100px;font-weight:700;}
.code-st.used{background:#4A1010;color:#F44336;}
.code-st.unused{background:#0D2B3E;color:#42A5F5;}
.btn-gen{background:#1A5276;color:white;border:none;padding:7px 15px;border-radius:7px;cursor:pointer;font-size:0.78rem;font-weight:700;margin-top:7px;}

/* ── ABONNEMENT PRO ── */
.sub-banner{
  background:linear-gradient(135deg,#1A0D00 0%,#2A1500 50%,#1A0D00 100%);
  border:2px solid var(--or);border-radius:14px;padding:18px 24px;
