function toggleToit(id, checked) {
  const ti = toitureItems.find(t => t.id === id);
  if(ti){ ti.checked = checked; ti.qte_manual = null; }
  const wrap = v('wrap-'+id);
  if(wrap) wrap.classList.toggle('checked', checked);
  const fields = wrap?.querySelectorAll('input[type=number]');
  fields?.forEach(f => f.disabled = !checked);
  onMaisonChange();
}

function updateToitItem(id, prop, val) {
  const ti = toitureItems.find(t => t.id === id);
  if(ti) ti[prop] = val;
  calcMaison();
}

function onMaisonChange() {
  renderPieces();
  // Auto piliers/poutres
  const surf_total = pieces.reduce((s,p)=>s+p.lon*p.lar, 0);
  const perim_m = Math.round(Math.sqrt(surf_total)*4*1.2);
  const pilAuto = Math.ceil(perim_m/3) + 4;
  const poutAuto = Math.ceil(Math.sqrt(surf_total)/3) * 2;
  setAutoVal('mPiliers', pilAuto);
  setAutoVal('mPoutres', poutAuto);
  // Auto nb piliers clôture
  const lon_c = getVal('cLon');
  const esp_c = getVal('cEspPil') || 3;
  setAutoVal('cNbPil', Math.ceil(lon_c/esp_c)+1);
  calcMaison();
}

function calcMaison() {
  const niv = getInt('mNiv') || 1;

  // ── GARDE : aucune pièce ou surface nulle ──
  const surf_check = pieces.reduce((s,p)=>s+p.lon*p.lar, 0);
  if (!pieces.length || !surf_check) {
    maisonData = { total:0, mat:0, mo:0 };
    renderCats('maison-cats', [], 'maison');
    v('maison-info').innerHTML = `⚠️ Ajoutez au moins une pièce avec des dimensions pour estimer.`;
    updateGrandTotal();
    return;
  }

  const hsp = getVal('mHsp') || 2.7;
  const mur = getSel('mMur');
  const typePilier = getSel('mTypePilier') || 'beton';
  const typeFen = getSel('mTypeFen') || 'bois';
  const pente = getVal('mPente') || 30;
  const versants = getInt('mVersants') || 2;
  const coeff = getSel('mRegion') === 'autres' ? 1.05 : 1.0;
  const nbPil = getInt('mPiliers');
  const secPil = getSel('mSecPil') || '25x25';
  const nbPout = getInt('mPoutres');
  const nbSdb = getInt('mNbSdb'); const nbWc = getInt('mNbWc');
  const nbCui = getInt('mNbCui');
  const elec = getSel('mElec') || 'standard';
  const chauffe = getSel('mChauffe');
  const enduit = getSel('mEnduit') || 'none';
  const peinture = getSel('mPeinture') || 'none';
  const peintureZone = getSel('mPeintureZone') || 'int';

  const surf_total = pieces.reduce((s,p)=>s+p.lon*p.lar, 0);
  const nb_pieces = pieces.length;
  const perim = Math.round(Math.sqrt(surf_total)*4*1.2);
  const surf_mur_int = perim * hsp * niv;
  const surf_mur_ext = perim * hsp * niv * 1.05; // ext légèrement plus grand
  const surf_mur = surf_mur_int;

  // ── FONDATION ──
  const vol_fond = surf_total * 0.12 * niv;
  const sacs_f = Math.ceil(vol_fond * 6 * coeff);
  const sable_f = +(vol_fond * 0.5).toFixed(1);
  const gravier_f = +(vol_fond * 0.8).toFixed(1);
  const cout_fond = sacs_f * P.ciment_sac.prix + sable_f * P.sable_m3.prix + gravier_f * P.gravier_m3.prix;

  // ── MURS — 55 briques/m² ──
  let nb_briques=0, nb_parpaings=0, vol_pierre=0;
  if (mur==='brique') nb_briques = Math.ceil(surf_mur * 55);
  else if (mur==='parpaing') nb_parpaings = Math.ceil(surf_mur / 0.084);
  else vol_pierre = +(surf_mur * 0.20).toFixed(1);
  const sacs_mort = Math.ceil(surf_mur * 0.65);
  const cout_mur = nb_briques*P.brique_pc.prix + nb_parpaings*P.parpaing_pc.prix + vol_pierre*P.pierre_m3.prix + sacs_mort*P.mortier_sac.prix;

  // ── STRUCTURE ──
  const [pw,pd] = secPil.split('x').map(x=>+x/100);
  let cout_struct = 0, vol_beton_struct = 0;
  let bPil10, bPil8, bLint8, bChain10, kg_fil_struct, sacs_pil;
  let ml_ha10_pil=0, ml_ha8_cad=0, ml_lint=0, ml_chain=0;

  if (typePilier === 'beton') {
    const vol_pil = pw*pd*hsp*niv*nbPil;
    sacs_pil = Math.ceil(vol_pil*6*coeff);
    vol_beton_struct = vol_pil;
    ml_ha10_pil = 4*hsp*niv*nbPil*FACTEUR_CHUTE_FER;
    const nb_cad_pil = Math.ceil(hsp/0.175)*niv*nbPil;
    ml_ha8_cad = nb_cad_pil*(pw+pd)*2*FACTEUR_CHUTE_FER;
    bPil10 = mlToBarres(ml_ha10_pil,'fer_ha10');
    bPil8 = mlToBarres(ml_ha8_cad,'fer_ha8');
    // Linteaux
    const total_ouv_lint = pieces.reduce((s,p)=>s+p.portes+p.fenetres, 0);
    ml_lint = total_ouv_lint * 1.6 * FACTEUR_CHUTE_FER;
    bLint8 = mlToBarres(ml_lint, 'fer_ha8');
    // Chaînages
    ml_chain = perim * niv * 2 * FACTEUR_CHUTE_FER;
    bChain10 = mlToBarres(ml_chain, 'fer_ha10');
    kg_fil_struct = filAttache(0, ml_ha8_cad+ml_lint, ml_ha10_pil+ml_chain, 0);
    // Coffrage piliers béton
    const surf_cof_pil = (pw+pd)*2*hsp*niv*nbPil;
    const nb_planches_pil = Math.ceil(surf_cof_pil / (2*0.15));
    const nb_etais_pil = Math.ceil(nbPil * hsp / 0.8);
    const clous_struct = calcClous(surf_cof_pil, 0);
    cout_struct = (sacs_pil*P.ciment_sac.prix) + bPil10.cout + bPil8.cout + bLint8.cout + bChain10.cout
      + Math.ceil(kg_fil_struct)*P.fil_attache.prix
      + nb_planches_pil*P.planche_2m.prix + nb_etais_pil*P.bois_rond_4m.prix + clous_struct.cout;
  } else {
    // Piliers brique — pas de coffrage, juste mortier supplémentaire
    const nb_briques_pil = Math.ceil(nbPil * hsp * niv * 16); // ~16 briques/m courant pilier brique
    sacs_pil = Math.ceil(nbPil * hsp * niv * 0.3);
    bPil10 = {nb:0,cout:0}; bPil8 = {nb:0,cout:0};
    const total_ouv_lint = pieces.reduce((s,p)=>s+p.portes+p.fenetres, 0);
    ml_lint = total_ouv_lint * 1.6 * FACTEUR_CHUTE_FER;
    bLint8 = mlToBarres(ml_lint, 'fer_ha8');
    ml_chain = perim * niv * 2 * FACTEUR_CHUTE_FER;
    bChain10 = mlToBarres(ml_chain, 'fer_ha10');
    kg_fil_struct = filAttache(0, ml_lint, ml_chain, 0);
    cout_struct = nb_briques_pil*P.brique_pc.prix + sacs_pil*P.mortier_sac.prix
      + bLint8.cout + bChain10.cout + Math.ceil(kg_fil_struct)*P.fil_attache.prix;
  }

  // ── TOITURE ──
  const fact_pente = 1 / Math.cos(pente * Math.PI / 180);
  const surf_toit = surf_total * fact_pente * (versants === 4 ? 1.15 : 1.0);
  const perim_toit = perim * 1.1;
  let cout_toit = 0; const toit_lines = [];

  toitureItems.forEach(ti => {
    if (!ti.checked) return;
    let qte = 0;
    if (ti.id === 'ti_tole') {
      qte = ti.qte_manual != null ? ti.qte_manual : Math.ceil(surf_toit / 0.9);
      cout_toit += qte * P.tole_m2.prix;
      toit_lines.push({ label:'Tôle ondulée', qte:`${qte} m²`, prix: P.tole_m2.prix, cout: qte*P.tole_m2.prix });
    } else if (ti.id === 'ti_tuile') {
      qte = ti.qte_manual != null ? ti.qte_manual : Math.ceil(surf_toit / 0.085);
      cout_toit += qte * P.tuile_pc.prix;
      toit_lines.push({ label:'Tuiles béton', qte:`${qte} pièces`, prix: P.tuile_pc.prix, cout: qte*P.tuile_pc.prix });
    } else {
      // Calcul auto en pièces de 4m
      const esp = ti.esp > 0 ? ti.esp : 0.5;
      if (ti.id === 'ti_madrier') {
        qte = ti.qte_manual != null ? ti.qte_manual : Math.ceil(surf_total / 4); // faîtière selon longueur plancher
      } else if (ti.id === 'ti_derive') {
        qte = ti.qte_manual != null ? ti.qte_manual : Math.ceil(perim_toit / 4);
      } else {
        qte = ti.qte_manual != null ? ti.qte_manual : Math.ceil(surf_toit / (4 * esp));
      }
      // Mettre à jour affichage qte
      const qteEl = v('qte-'+ti.id);
      if(qteEl) qteEl.value = qte;
      const prix = P[ti.key]?.prix || 0;
      cout_toit += qte * prix;
      toit_lines.push({ label:`${ti.label} (${ti.sub})`, qte:`${qte} pièces`, prix, cout: qte*prix });
    }
    const qteEl = v('qte-'+ti.id);
    if(qteEl && (ti.id==='ti_tole'||ti.id==='ti_tuile')) qteEl.value = qte;
  });

  // ── SOL par pièce ──
  const carreGroupe = {};
  let cout_sol = 0;
  pieces.forEach(p => {
    const fmt_sol = p.sol;
    const surf_p = p.lon * p.lar * niv * 1.10; // +10% chutes
    if (FORMAT_CARRE[fmt_sol]) {
      const key_c = 'carre_' + fmt_sol.replace('x','x');
      const prix_c = P[key_c]?.prix || P.carre_30x30.prix;
      const nb_pc = Math.ceil(surf_p / FORMAT_CARRE[fmt_sol].surf);
      const cout_c = Math.ceil(surf_p) * prix_c;
      carreGroupe[fmt_sol] = (carreGroupe[fmt_sol]||{surf:0,pieces_nb:0,cout:0,prix:prix_c});
      carreGroupe[fmt_sol].surf += Math.ceil(surf_p);
      carreGroupe[fmt_sol].pieces_nb += nb_pc;
      carreGroupe[fmt_sol].cout += cout_c;
      // Colle : 5kg/m² → ~1 sac 25kg pour 5m²
      cout_sol += cout_c + Math.ceil(surf_p/5)*P.colle_sac.prix;
    } else if (fmt_sol === 'Chape ciment') {
      const vol_ch = p.lon*p.lar*0.05;
      cout_sol += Math.ceil(vol_ch*5)*P.ciment_sac.prix;
    }
    // Parquet = même coût approx carrelage standard
    else if (fmt_sol === 'Parquet bois') {
      cout_sol += Math.ceil(surf_p) * P.carre_40x40.prix;
    }
  });

  // ── MENUISERIE — fenêtre bois ou alu ──
  const nb_portes = pieces.reduce((s,p)=>s+p.portes,0) + 1;
  const nb_fen = pieces.reduce((s,p)=>s+p.fenetres,0);
  const prix_fen = typeFen === 'alu' ? P.fenetre_alu.prix : P.fenetre_bois.prix;
  const cout_men = nb_portes*P.porte_bois.prix + nb_fen*prix_fen;

  // ── FINITIONS — enduit et peinture AU M² ──
  let cout_fin = 0, surf_enduit = 0, surf_peinture = 0;
  if (enduit !== 'none') {
    surf_enduit = enduit==='both' ? surf_mur_int+surf_mur_ext : enduit==='int' ? surf_mur_int : surf_mur_ext;
    cout_fin += surf_enduit * (P.enduit_m2.prix + P.enduit_mo_m2.prix);
  }
  if (peinture !== 'none') {
    const coats = peinture==='1c'?1:peinture==='2c'?2:3;
    surf_peinture = peintureZone==='both' ? surf_mur_int+surf_mur_ext : peintureZone==='int' ? surf_mur_int : surf_mur_ext;
    cout_fin += surf_peinture * (P.peinture_m2.prix + P.peinture_mo_m2.prix) * coats;
  }
  if (v('fin-info')) {
    const parts = [];
    if(enduit!=='none') parts.push(`Enduit : ${surf_enduit.toFixed(0)} m²`);
    if(peinture!=='none') parts.push(`Peinture : ${surf_peinture.toFixed(0)} m²`);
    v('fin-info').style.display = parts.length ? 'block' : 'none';
    v('fin-info').innerHTML = parts.join(' | ') + (parts.length ? ` → <b>${fmt(cout_fin)}</b>` : '');
  }

  // ── SDB / CUISINE ──
  const cout_sdb = nbSdb * SDB_DATA[sdbStanding].prix + nbWc * P.wc_seul.prix;
  const cout_cui = nbCui * CUI_DATA[cuiStanding].prix;

  // ── ÉLECTRICITÉ ──
  const nb_total_pieces = nb_pieces + nbSdb + nbCui;
  const prix_elec = { base:P.elec_base.prix, standard:P.elec_std.prix, complet:P.elec_comp.prix }[elec];
  let cout_elec = nb_total_pieces * prix_elec + P.tableau_elec.prix;
  if (chauffe==='elec') cout_elec += P.ce_elec.prix;
  else if (chauffe==='solaire') cout_elec += P.ce_solaire.prix;

  // ── EAU DE GÂCHAGE ──
  const vol_beton_m = vol_fond + vol_beton_struct;
  const sacs_mortier_m = sacs_mort + sacs_f;
  const eau_m = calcEau(vol_beton_m, sacs_mortier_m);

  // ── CLOUS (coffrage toiture + piliers) ──
  const nb_pieces_toit = toitureItems.filter(t=>t.checked).reduce((s,t)=>{
    const qteEl = v('qte-'+t.id); return s + (qteEl ? +qteEl.value : 0);
  }, 0);
  const clous_m = calcClous(surf_total * 0.3, nb_pieces_toit);

  const mat = cout_fond+cout_mur+cout_struct+cout_toit+cout_sol+cout_men+cout_fin+cout_sdb+cout_cui+cout_elec+eau_m.cout+clous_m.cout;
  const mo = Math.round(mat * P.mo_maison.prix / 100);
  const total = mat + mo;

  const total_ouv = pieces.reduce((s,p)=>s+p.portes+p.fenetres, 0);

  maisonData = {
    total, mat, mo, cout_fond, cout_mur, cout_struct, cout_toit, cout_sol, cout_men,
    cout_fin, cout_sdb, cout_cui, cout_elec, eau_m, clous_m,
    sacs_f, sable_f, gravier_f, nb_briques, nb_parpaings, sacs_mort,
    bPil10, bPil8, bLint8, bChain10, kg_fil_struct, sacs_pil,
    toit_lines, surf_toit, perim_toit, pente,
    carreGroupe, nb_portes, nb_fen, total_ouv,
    nbSdb, nbWc, nbCui, sdbStanding, cuiStanding, elec, chauffe,
    nb_pieces, nb_total_pieces, prix_elec,
    typePilier, typeFen, prix_fen,
    enduit, peinture, peintureZone, surf_enduit, surf_peinture,
    surf_total, surf_mur: surf_mur_int, surf_mur_ext, perim, niv, hsp, mur,
    nbPil, secPil, nbPout, ml_ha10_pil, ml_ha8_cad, ml_lint, ml_chain
  };

  const cats = [
    {nom:'🏗 Fondation', montant:cout_fond},
    {nom:'🧱 Maçonnerie', montant:cout_mur},
    {nom:'🏛 Structure portante', montant:cout_struct},
    {nom:'🏠 Toiture', montant:cout_toit},
    {nom:'🪵 Sol & Carrelage', montant:cout_sol},
    {nom:'🚪 Menuiserie', montant:cout_men},
    {nom:'🎨 Finitions', montant:cout_fin},
    {nom:'🚿 SDB & WC', montant:cout_sdb},
    {nom:'🍳 Cuisine', montant:cout_cui},
    {nom:'⚡ Électricité', montant:cout_elec},
    {nom:'💧 Eau de gâchage', montant:eau_m.cout},
    {nom:'🔨 Clous', montant:clous_m.cout},
    {nom:'👷 Main d\'œuvre (40%)', montant:mo},
  ];
  renderCats('maison-cats', cats, 'maison');
  v('maison-info').innerHTML = `<b>${surf_total.toFixed(1)} m²</b> | ${niv} niv. | ${nb_pieces} pièces | ${nb_portes} portes · ${nb_fen} fenêtres · ${total_ouv} linteaux | <b>Estimation : ${fmt(total)}</b>`;
  updateGrandTotal();
}

// ═══════════════════════════════════════════════════════════════
// CALCUL CLÔTURE
// ═══════════════════════════════════════════════════════════════
function onClotureChange() {
  const lon = getVal('cLon');
  const esp = getVal('cEspPil') || 3;
  setAutoVal('cNbPil', Math.ceil(lon/esp)+1);
  calcCloture();
}

function calcCloture() {
  const lon = getVal('cLon');

  // ── GARDE : longueur nulle ──
  if (!lon) {
    clotureData = { total:0, mat_tot:0, mo:0 };
    renderCats('cloture-cats', [], 'cloture');
    v('cloture-info').innerHTML = `⚠️ Veuillez saisir la longueur totale de la clôture.`;
    updateGrandTotal();
    return;
  }

  const haut = getVal('cHaut') || 2.0;
  const mat = getSel('cMat');
  const fond = getSel('cFond');
  const portails = getInt('cPortails');
  const typePortail = getSel('cTypePortail');
  const coeff = getSel('cRegion') === 'autres' ? 1.05 : 1.0;

  const esp_pil = getVal('cEspPil') || 3;
  const nb_pil_auto = Math.ceil(lon/esp_pil)+1;
  setAutoVal('cNbPil', nb_pil_auto);
  const nb_pil = getInt('cNbPil') || nb_pil_auto;
  const secPil = getSel('cSecPil') || '20x20';
  const [pw,pd] = secPil.split('x').map(x=>+x/100);

  // Fondation
  const prof_f = fond==='simple' ? 0.30 : 0.50;
  const ep_mur = 0.15;
  const vol_fond = (lon * ep_mur * prof_f) + (pw*pd*prof_f*nb_pil);
  const sacs_f = Math.ceil(vol_fond * 6 * coeff);
  const sable_f = +(vol_fond*0.5).toFixed(1);
  const gravier_f = +(vol_fond*0.8).toFixed(1);
  const cout_fond = sacs_f*P.ciment_sac.prix + sable_f*P.sable_m3.prix + gravier_f*P.gravier_m3.prix;

  // Piliers
  const vol_pil = pw*pd*haut*nb_pil;
  const sacs_pil = Math.ceil(vol_pil*6*coeff);
  const ml_ha8_long = 4*haut*nb_pil*FACTEUR_CHUTE_FER;
  const nb_cad = Math.ceil(haut/0.20)*nb_pil;
  const ml_ha6_cad = nb_cad*(pw+pd)*2*FACTEUR_CHUTE_FER;
  const bP8 = mlToBarres(ml_ha8_long,'fer_ha8');
  const bP6 = mlToBarres(ml_ha6_cad,'fer_ha6');
  const kg_fil_pil = filAttache(ml_ha6_cad, ml_ha8_long, 0, 0);
  const cout_pil = sacs_pil*P.ciment_sac.prix + bP8.cout + bP6.cout + Math.ceil(kg_fil_pil)*P.fil_attache.prix;

  // Mur (surface réelle = lon×haut moins zones piliers)
  const surf_mur = lon*haut - nb_pil*(pw*haut);
  let nb_parpaings=0, nb_briques=0, vol_pierre=0;
  if (mat==='parpaing') nb_parpaings = Math.ceil(surf_mur/0.084);
  else if (mat==='brique') nb_briques = Math.ceil(surf_mur/0.023);
  else vol_pierre = +(surf_mur*0.20).toFixed(1);
  const sacs_mort = Math.ceil(surf_mur*0.65);
  const cout_mur_c = nb_parpaings*P.parpaing_pc.prix + nb_briques*P.brique_pc.prix + vol_pierre*P.pierre_m3.prix + sacs_mort*P.mortier_sac.prix;

  // Chaînages horizontaux (bas + mi + haut)
  const ml_chain = lon * 3 * FACTEUR_CHUTE_FER;
  const bChain = mlToBarres(ml_chain, 'fer_ha8');
  const cout_chain = bChain.cout;

  // Enduit clôture — au m² (optionnel, inclus par défaut)
  const surf_end_c = (surf_mur + nb_pil*(pw+pd)*2*haut) * 2;
  const cout_end = surf_end_c * (P.enduit_m2.prix + P.enduit_mo_m2.prix);

  // Portail
  const prixPortail = { '3m':P.portail_3m.prix, '4m':P.portail_4m.prix, 'coulissant':P.portail_mot.prix }[typePortail] || P.portail_3m.prix;
  const cout_portail = portails * prixPortail;

  // Eau de gâchage clôture
  const vol_beton_c = vol_fond + vol_pil;
  const eau_c = calcEau(vol_beton_c, sacs_mort + sacs_f);

  // Clous coffrage piliers
  const surf_cof_c = (pw+pd)*2*haut*nb_pil;
  const clous_c = calcClous(surf_cof_c, 0);

  const mat_tot = cout_fond+cout_pil+cout_mur_c+cout_chain+cout_portail+cout_end+eau_c.cout+clous_c.cout;
  const mo = Math.round(mat_tot * P.mo_cloture.prix / 100);
  const total = mat_tot + mo;

  clotureData = {
    total, mat_tot, mo, cout_fond, cout_pil, cout_mur_c, cout_chain, cout_portail, cout_end,
    sacs_f, sable_f, gravier_f, sacs_pil, bP8, bP6, kg_fil_pil,
    nb_parpaings, nb_briques, sacs_mort, bChain, surf_end_c, portails, prixPortail, typePortail,
    eau_c, clous_c,
    lon, haut, nb_pil, secPil, esp_pil, surf_mur
  };

  const cats = [
    {nom:'🏗 Fondation', montant:cout_fond},
    {nom:'🏛 Piliers de clôture', montant:cout_pil},
    {nom:'🧱 Maçonnerie', montant:cout_mur_c},
    {nom:'🔩 Chaînages', montant:cout_chain},
    {nom:'🚪 Portail(s)', montant:cout_portail},
    {nom:'🎨 Enduit (2 faces)', montant:cout_end},
    {nom:'💧 Eau de gâchage', montant:eau_c.cout},
    {nom:'👷 Main d\'œuvre (30%)', montant:mo},
  ];
  renderCats('cloture-cats', cats, 'cloture');
  v('cloture-info').innerHTML = `${lon} m × ${haut} m — <b>${nb_pil} piliers ${secPil}cm</b> esp. ${esp_pil}m — Surface mur : <b>${surf_mur.toFixed(1)} m²</b> | <b>Estimation : ${fmt(total)}</b>`;
  updateGrandTotal();
}

// ═══ RENDU CATÉGORIES (FREEMIUM) ═══
function renderCats(id, cats, type) {
  const unlocked = unlockedTypes[type] || false;
  v(id).innerHTML = cats.filter(c => c.montant > 0).map(c => `
    <div class="cat-card">
      <div>
        <div class="cat-name">${c.nom}</div>
        ${!unlocked ? '<div class="cat-sub">Masqué — débloqué après paiement</div>' : ''}
      </div>
      <div class="cat-amt${!unlocked?' blurred':''}">${fmt(c.montant)}</div>
    </div>`).join('');
  if (unlocked) v(id + '-unlock-hint' ) && (v(id + '-unlock-hint').style.display='none');
}

// ═══ GRAND TOTAL ═══
function updateGrandTotal() {
  const activePanel = document.querySelector('.panel.active');
  let t = 0;
  if (activePanel) {
    const id = activePanel.id;
    if (id === 'panel-dalle') t = dalleData.total || 0;
    else if (id === 'panel-maison') t = maisonData.total || 0;
    else if (id === 'panel-cloture') t = clotureData.total || 0;
  }
  const el = v('grand-total');
  if(el){ el.textContent = fmt(t); el.classList.add('bump'); setTimeout(()=>el.classList.remove('bump'),350); }
}

