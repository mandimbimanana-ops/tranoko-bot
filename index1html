    <div class="toit-item${ti.checked?' checked':''}" id="wrap-${ti.id}">
      <div class="toit-item-top">
        <input type="checkbox" id="${ti.id}" ${ti.checked?'checked':''} onchange="toggleToit('${ti.id}',this.checked)">
        <label for="${ti.id}" class="toit-item-label">${ti.label}</label>
      </div>
      <div class="toit-item-sub">${ti.sub}</div>
      ${ti.id !== 'ti_tole' && ti.id !== 'ti_tuile' ? `
