function calcDalle() {
  const lon = getVal('dLon');
  const lar = getVal('dLar');

  // ── GARDE : dimensions nulles → tout à zéro ──
  if (!lon || !lar) {
    dalleData = { total:0, mat:0, mo:0 };
    renderCats('dalle-cats', [], 'dalle');
    v('dalle-info').innerHTML = `⚠️ Veuillez saisir la longueur et la largeur de la dalle.`;
    updateGrandTotal();
    return;
  }

  const ep = getVal('dEp') / 100;
  const dos = getVal('dDos');
  const fer = getSel('dFer');
  const maille = getVal('dMaille') / 100;
  const niv = getSel('dNiveau');
  const coeff = getSel('dRegion') === 'autres' ? 1.05 : 1.0;

  const surf = lon * lar;
  const vol = surf * ep;
  const perim = 2*(lon+lar);

  // ── BÉTON DALLE ──
  const sacs_d = Math.ceil(vol * (dos/50) * coeff);
  const sable_d = +(vol * 0.5 * coeff).toFixed(2);
  const gravier_d = +(vol * 0.8 * coeff).toFixed(2);
  const cout_beton_d = sacs_d * P.ciment_sac.prix + sable_d * P.sable_m3.prix + gravier_d * P.gravier_m3.prix;

  // ── FERRAILLAGE DALLE (nappes correctes) ──
  let ml_fer_d = 0, key_fer = 'fer_ha8', label_fer = '';
  if (fer === 'treillis') {
    const nb_tr = Math.ceil(surf * 1.1);
    // Treillis → prix au m², traité séparément dans affichage
    ml_fer_d = 0;
    label_fer = `Treillis soudé ST25 — ${nb_tr} m²`;
  } else {
    const nb_barres_x = Math.ceil(lon / maille) + 1;
    const nb_barres_y = Math.ceil(lar / maille) + 1;
    const ml_nappe = (nb_barres_x * lar) + (nb_barres_y * lon);
    ml_fer_d = Math.ceil(ml_nappe * 2 * coeff * FACTEUR_CHUTE_FER); // double nappe + chutes
    key_fer = fer === 'ha10' ? 'fer_ha10' : 'fer_ha8';
    label_fer = fer === 'ha10' ? `HA10 double nappe — maille ${getVal('dMaille')}cm` : `HA8 double nappe — maille ${getVal('dMaille')}cm`;
  }

  let cout_fer_d = 0, nb_barres_dalle = 0;
  if (fer === 'treillis') {
    const nb_tr = Math.ceil(surf * 1.1);
    cout_fer_d = nb_tr * P.treillis_m2?.prix || nb_tr * 12000;
    nb_barres_dalle = nb_tr;
  } else {
    const b = mlToBarres(ml_fer_d, key_fer);
    cout_fer_d = b.cout; nb_barres_dalle = b.nb;
  }
  const kg_fil_d = filAttache(0, fer==='ha8'?ml_fer_d:0, fer==='ha10'?ml_fer_d:0, 0);
  cout_fer_d += Math.ceil(kg_fil_d) * P.fil_attache.prix;

  // ── STRUCTURE (étage/terrasse seulement) ──
  let cout_struct = 0, struct_detail = {};
  if (niv !== 'rdc') {
    const nbPil = getInt('dPiliers');
    const secPil = getSel('dSecPil') || '25x25';
    const hPil = getVal('dHPil') || 2.7;
    const nbPout = getInt('dPoutres');
    const secPout = getSel('dSecPout') || '25x40';
    const lPout = getVal('dLPout') || lar;

    const [pw, pd] = secPil.split('x').map(x => +x/100);
    const [bw, bh] = secPout.split('x').map(x => +x/100);

    // Béton piliers
    const vol_pil = pw * pd * hPil * nbPil;
    const sacs_pil = Math.ceil(vol_pil * (dos/50) * coeff);
    const sable_pil = +(vol_pil * 0.5).toFixed(2);
    const gravier_pil = +(vol_pil * 0.8).toFixed(2);

    // Ferraillage piliers : 4 HA10 long. + cadres HA8
    const ml_ha10_pil = 4 * hPil * nbPil * FACTEUR_CHUTE_FER;
    const nb_cadres = Math.ceil(hPil / 0.175) * nbPil; // esp. moyen 17.5cm (10cm noeud + 20cm courant)
    const perim_cadre = (pw + pd) * 2 + 0.10; // + recouvrement
    const ml_ha8_cad = nb_cadres * perim_cadre * FACTEUR_CHUTE_FER;

    const b10_pil = mlToBarres(ml_ha10_pil, 'fer_ha10');
    const b8_cad = mlToBarres(ml_ha8_cad, 'fer_ha8');
    const kg_fil_pil = filAttache(0, ml_ha8_cad, ml_ha10_pil, 0);

    const cout_beton_pil = sacs_pil * P.ciment_sac.prix + sable_pil * P.sable_m3.prix + gravier_pil * P.gravier_m3.prix;
    const cout_fer_pil = b10_pil.cout + b8_cad.cout + Math.ceil(kg_fil_pil) * P.fil_attache.prix;

    // Béton poutres
    const vol_pout = bw * bh * lPout * nbPout;
    const sacs_pout = Math.ceil(vol_pout * (dos/50) * coeff);
    const sable_pout = +(vol_pout * 0.5).toFixed(2);
    const gravier_pout = +(vol_pout * 0.8).toFixed(2);
    const ml_ha10_pout = 6 * lPout * nbPout * FACTEUR_CHUTE_FER; // 6 barres HA10
    const ml_ha8_etrier_pout = Math.ceil(lPout / 0.175) * ((bw+bh)*2+0.1) * nbPout * FACTEUR_CHUTE_FER;
    const b10_pout = mlToBarres(ml_ha10_pout, 'fer_ha10');
    const b8_pout = mlToBarres(ml_ha8_etrier_pout, 'fer_ha8');
    const kg_fil_pout = filAttache(0, ml_ha8_etrier_pout, ml_ha10_pout, 0);

    const cout_beton_pout = sacs_pout * P.ciment_sac.prix + sable_pout * P.sable_m3.prix + gravier_pout * P.gravier_m3.prix;
    const cout_fer_pout = b10_pout.cout + b8_pout.cout + Math.ceil(kg_fil_pout) * P.fil_attache.prix;

    cout_struct = cout_beton_pil + cout_fer_pil + cout_beton_pout + cout_fer_pout;
    struct_detail = {
      nbPil, secPil, hPil, sacs_pil, sable_pil, gravier_pil,
      b10_pil, b8_cad, kg_fil_pil, cout_beton_pil, cout_fer_pil,
      nbPout, secPout, lPout, sacs_pout, sable_pout, gravier_pout,
      b10_pout, b8_pout, kg_fil_pout, cout_beton_pout, cout_fer_pout,
      ml_ha10_pil, ml_ha8_cad, ml_ha10_pout, ml_ha8_etrier_pout
    };
  }

  // ── COFFRAGE ──
  let cout_cof = 0, cof_detail = {};
  if (niv !== 'rdc' && v('dCofP4m')) {
    const np4m = getInt('dCofP4m');
    const np2m = getInt('dCofP2m');
    const netais = getInt('dCofEtais');
    cout_cof = np4m * P.planche_4m.prix + np2m * P.planche_2m.prix + netais * P.bois_rond_4m.prix;
    cof_detail = { np4m, np2m, netais, surf };
  }

  // ── ÉTANCHÉITÉ TERRASSE ──
  let cout_et = 0;
  if (niv === 'terrasse') {
    const surfEt = Math.ceil(surf * 1.05);
    cout_et = surfEt * 8000;
  }

  // ── HÉRISSON & ENCADREMENT (RDC) ──
  let cout_herisson = 0, herisson_detail = {};
  const cardHer = v('card-herisson');
  if (niv === 'rdc') {
    if(cardHer) cardHer.style.display = 'block';
    const heriMat  = getSel('dHerisson') || 'gravier';
    const heriEp   = (getVal('dHeriEp') || 15) / 100;
    const vol_her  = surf * heriEp;
    // Coût selon matériau
    if (heriMat === 'gravier') {
      cout_herisson = Math.ceil(vol_her) * P.gravier_m3.prix;
    } else if (heriMat === 'terre') {
      cout_herisson = Math.ceil(vol_her) * 15000; // terre rouge ~15000/m³
    } else if (heriMat === 'briques') {
      cout_herisson = 0; // restes chantier = gratuit
    } else { // mixte
      cout_herisson = Math.ceil(vol_her * 0.5) * 15000 + Math.ceil(vol_her * 0.5) * P.gravier_m3.prix;
    }
    // Encadrement planches bordure dalle RDC
    const nb_p_bord = Math.ceil(perim / 2); // planches 2m pour border
    const cout_encadrement = nb_p_bord * P.planche_2m.prix;
    cout_herisson += cout_encadrement;
    herisson_detail = { heriMat, vol_her: vol_her.toFixed(2), nb_p_bord, cout_encadrement };
    if(v('herisson-info')) {
      const matLab = {gravier:'Cailloux/Grosses pierres',terre:'Terre rouge',briques:'Briques recyclées (gratuit)',mixte:'Mixte terre + cailloux'}[heriMat];
      v('herisson-info').innerHTML = `${matLab} — ${vol_her.toFixed(2)} m³ | Encadrement : ${nb_p_bord} planches 2m | <b>Coût : ${fmt(cout_herisson)}</b>`;
    }
  } else {
    if(cardHer) cardHer.style.display = 'none';
  }

  // ── EAU DE GÂCHAGE dalle ──
  const vol_beton_total_d = vol + (struct_detail.sacs_pil ? (struct_detail.sacs_pil/6) : 0);
  const eau_d = calcEau(vol_beton_total_d, 0);

  // ── CLOUS coffrage dalle ──
  const surf_cof_d = niv !== 'rdc' ? surf : perim * ep;
  const clous_d = calcClous(surf_cof_d, 0);
  const cout_clous_d = clous_d.cout;

  const mat = cout_beton_d + cout_fer_d + cout_struct + cout_cof + cout_et + cout_herisson + eau_d.cout + cout_clous_d;
  const mo = Math.round(mat * P.mo_dalle.prix / 100);
  const total = mat + mo;

  dalleData = {
    total, mat, mo, cout_beton_d, cout_fer_d, cout_struct, cout_cof, cout_et, cout_herisson,
    sacs_d, sable_d, gravier_d, nb_barres_dalle, label_fer, key_fer, fer, ml_fer_d,
    kg_fil_d, struct_detail, cof_detail, herisson_detail,
    eau_d, clous_d, cout_clous_d,
    surf, vol, perim, lon, lar, ep: ep*100, dos, niv, coeff
  };

  const cats = [
    { nom:'🏗 Béton dalle', montant: cout_beton_d + cout_herisson },
    { nom:'🔩 Ferraillage dalle', montant: cout_fer_d },
    { nom:'🏛 Structure (piliers+poutres)', montant: cout_struct },
    { nom:'🪵 Coffrage & Clous', montant: cout_cof + cout_clous_d },
    { nom:'💧 Étanchéité', montant: cout_et },
    { nom:'💧 Eau de gâchage', montant: eau_d.cout },
    { nom:'👷 Main d\'œuvre', montant: mo },
  ];
  renderCats('dalle-cats', cats, 'dalle');

  const nivLab = { rdc:'RDC',etage:'Étage',terrasse:'Terrasse' }[niv];
  v('dalle-info').innerHTML = `<span class="nbadge nb-${niv}">${nivLab}</span> ${lon}×${lar} m — <b>${surf.toFixed(1)} m²</b> | Ép. <b>${ep*100}cm</b> | Vol. béton : <b>${vol.toFixed(3)} m³</b> | <b>Estimation : ${fmt(total)}</b>`;
  updateGrandTotal();
}

