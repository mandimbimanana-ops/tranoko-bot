function buildTable(title, rows, badgeClass) {
  const total = rows.reduce((s,r)=>s+(r.cout||0),0);
  const bClass = badgeClass || 'badge';
  return `
    <div class="rtitle">${title} <span class="${bClass}">${fmt(total)}</span></div>
    <table class="res">
      <thead><tr><th>Élément</th><th>Quantité</th><th>Prix unit.</th><th style="text-align:right">Montant</th></tr></thead>
      <tbody>
        ${rows.map(r=>`<tr>
          <td>${r.label}${r.note?`<br><span class="td-note">${r.note}</span>`:''}${r.dim?`<br><span class="td-dim">${r.dim}</span>`:''}</td>
          <td class="td-qty qty-blurred">${r.qte}</td>
          <td class="td-pu">${r.prix ? fmt(r.prix).replace(' Ar',' Ar/u') : '—'}</td>
          <td class="td-amt sub-blurred">${r.cout?fmt(r.cout):'—'}</td>
        </tr>`).join('')}
        <tr class="tr-total"><td colspan="3" style="font-weight:700;">Sous-total</td>
          <td class="td-amt sub-blurred">${fmt(total)}</td></tr>
      </tbody>
    </table>`;
}

