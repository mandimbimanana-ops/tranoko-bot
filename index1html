// ═══ ABONNEMENT PRO ═══

let proSession = null; // profil abonné actif en session
let currentPrintType = ''; // module à imprimer après saisie client
let devisCounter = 0; // compteur de devis session (incrémenté à chaque impression)

// Génération numéro devis : DEV-YYYY-NNN
function nextDevisNum() {
  const stored = JSON.parse(localStorage.getItem('tranoko_devis_counter') || '{"year":0,"num":0}');
  const y = new Date().getFullYear();
  const num = stored.year === y ? stored.num + 1 : 1;
  localStorage.setItem('tranoko_devis_counter', JSON.stringify({ year: y, num }));
  return `DEV-${y}-${String(num).padStart(3,'0')}`;
}

// Sauvegarder/charger abonnés
function getAbons() { try{ return JSON.parse(localStorage.getItem('tranoko_abons')||'[]'); }catch{return[];} }
function saveAbons(a) { try{ localStorage.setItem('tranoko_abons', JSON.stringify(a)); }catch{} }

// Vérifier si un abonnement est actif au chargement
function checkAbonnementActif() {
  const key = localStorage.getItem('tranoko_pro_actif');
  if (!key) return;
  try {
    const data = JSON.parse(key);
    const now = Date.now();
    if (data.expiry && now > data.expiry) {
      localStorage.removeItem('tranoko_pro_actif');
      return;
    }
    proSession = data;
    activerModePro(false);
  } catch {}
}

function activerModePro(showMsg) {
  // Débloquer tous les modules
  unlockedTypes.dalle = true;
  unlockedTypes.maison = true;
  unlockedTypes.cloture = true;
  // Badge header
  const badge = v('pro-badge-hdr');
  if (badge) { badge.classList.add('visible'); badge.textContent = '⭐ PRO — ' + (proSession?.nom || ''); }
  // Masquer bannière sub
  const banner = v('sub-banner');
  if (banner) banner.style.display = 'none';
  // Remplacer boutons "Payer" par boutons imprimer
  ['dalle','maison','cloture'].forEach(t => {
    const btn = document.querySelector(`button.btn-pay[onclick="openPay('${t}')"]`);
    if (btn) {
      btn.style.background = 'linear-gradient(135deg,#2D9945,#1A6B2A)';
      btn.innerHTML = `🖨 Générer le devis complet <span class="note">Abonnement Pro actif</span>`;
      btn.onclick = () => ouvrirDevisPro(t);
    }
  });
  if (showMsg) {
    calcDalle(); calcMaison(); calcCloture();
  }
}

// Ouvrir modal client avant impression
function ouvrirDevisPro(type) {
  // D'abord afficher le résultat si pas déjà visible
  const el = v(type + '-result');
  if (!el.classList.contains('visible')) showResult(type);

  currentPrintType = type;
  v('client-nom').value = '';
  v('client-tel').value = '';
  v('client-objet').value = '';
  // Prévisualisation émetteur
