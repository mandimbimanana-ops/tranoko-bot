// Validation code abonnement — via API
async function validateSubCode() {
  const input = v('sub-code-input').value.trim().toUpperCase();
  const errEl = v('sub-code-err'); const okEl = v('sub-code-ok');
  errEl.style.display='none'; okEl.style.display='none';

  if (!input.startsWith('ABON-')) {
    errEl.textContent = '❌ Code abonnement requis (ABON-XXXXXX)';
    errEl.style.display='block'; return;
  }

  v('sub-code-input').disabled = true;
  try {
    const result = await apiCall('/api/validate-code', {
      code: input,
      type: 'abon',
      deviceId: getDeviceId()
    });

    if (result.valid) {
      const now = Date.now();
      proSession = {
        nom: result.subscriberName || 'Professionnel',
        tel: result.subscriberTel || '',
        plan: result.plan || selectedPlan,
        expiry: result.expiresAt ? new Date(result.expiresAt).getTime() : now + 30*24*3600*1000,
        code: input,
        activatedAt: now
      };
      localStorage.setItem('tranoko_pro_actif', JSON.stringify(proSession));
      okEl.textContent = `✅ Abonnement activé — Bienvenue ${proSession.nom} !`;
      okEl.style.display='block';
      setTimeout(() => { closeSubModal(); activerModePro(true); }, 1500);
    } else {
      errEl.textContent = errMsg(result.reason);
      errEl.style.display='block';
    }
  } catch {
    errEl.textContent = '❌ Erreur réseau. Vérifiez votre connexion.';
    errEl.style.display='block';
  } finally {
    v('sub-code-input').disabled = false;
  }
}

// ── Génération code abonnement (admin) — via API ──
async function generateAbonCode() {
  const nom = v('abon-nom')?.value.trim();
  const tel = v('abon-tel')?.value.trim();
  const plan = v('abon-plan')?.value;
  const emetteur = v('abon-emetteur')?.value.trim() || 'Tranoko';

  if (!nom) { alert('Veuillez saisir le nom du professionnel.'); return; }
  if (!_adminPassCached) { alert('Session admin expirée. Reconnectez-vous.'); return; }

  const btn = event.target; btn.disabled = true; btn.textContent = '⏳ Génération…';
  try {
    const result = await apiCall('/api/generate-code', {
      adminPassword: _adminPassCached,
      type: 'abon',
      subscriberName: nom,
      subscriberTel: tel,
      plan,
      emetteur
    });

    if (result.code) {
      const abons = getAbons();
      abons.push({ code: result.code, nom, tel, plan, emetteur, date: new Date().toLocaleDateString('fr-MG') });
      saveAbons(abons); renderAbons();

      const expLabel = plan === 'annuel' ? 'Annuel 500 000 Ar' : 'Mensuel 120 000 Ar';
      const expDate = result.expiresAt ? new Date(result.expiresAt).toLocaleDateString('fr-MG') : '—';
      v('abon-result').innerHTML = `
        <div style="background:#0D2B1A;border:1.5px solid #2D9945;border-radius:9px;padding:12px 16px;margin-top:6px;">
          <div style="font-size:0.68rem;color:#4CAF50;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:4px;">✅ Code généré — copié !</div>
          <div style="font-family:'Space Mono',monospace;font-size:1.1rem;color:white;font-weight:700;letter-spacing:0.2em;">${result.code}</div>
          <div style="font-size:0.72rem;color:#888;margin-top:4px;">${nom} · ${expLabel} · Expire le ${expDate} · Émis par ${emetteur}</div>
          <button onclick="copyCode('${result.code}')" style="margin-top:8px;background:#2D9945;color:white;border:none;padding:5px 14px;border-radius:6px;cursor:pointer;font-size:0.75rem;font-weight:700;">📋 Copier le code</button>
        </div>`;
      try { await navigator.clipboard.writeText(result.code); } catch {}
    } else {
      alert('❌ Erreur : ' + (result.error || 'inconnue'));
    }
  } catch { alert('❌ Erreur réseau.'); }
  finally { btn.disabled=false; btn.textContent='⭐ Générer code abonnement'; }
}

function renderAbons() {
  const abons = getAbons();
  const el = v('abons-list');
  if (!el) return;
  if (!abons.length) { el.innerHTML = '<div style="color:#888;font-size:0.75rem;margin-top:6px;">Aucun abonnement généré.</div>'; return; }
  el.innerHTML = abons.slice().reverse().map(a => `
    <div class="code-item">
      <span class="code-val">${a.code}</span>
      <span style="font-size:0.75rem;color:#DDD;font-weight:600;">${a.nom}</span>
      <span style="font-size:0.68rem;color:#AAA;">${a.tel||''}</span>
      <span class="code-st unused" style="${a.plan==='annuel'?'background:#1A2D3D;color:#64B5F6;':'background:#1A2B1A;color:#81C784;'}">${a.plan==='annuel'?'📅 Annuel':'🗓 Mensuel'}</span>
      <span style="font-size:0.65rem;color:#666;">${a.date}</span>
      <button onclick="copyCode('${a.code}')" style="background:#1A5276;color:white;border:none;padding:2px 8px;border-radius:5px;cursor:pointer;font-size:0.68rem;">📋</button>
    </div>`).join('');
}

// ═══ VÉRIFICATION URL SECRÈTE ADMIN ═══
function checkAdminAccess() {
  const params = new URLSearchParams(window.location.search);
  const adminKey = params.get('admin');
  const ADMIN_SECRET = 'TRANOKO_SECRET_2024';
  
  if (adminKey === ADMIN_SECRET) {
    // Admin access granted
    localStorage.setItem('tranoko_admin_access', 'true');
    // Clean URL to hide the secret
    window.history.replaceState({}, document.title, window.location.pathname);
  } else {
    // No admin access
    localStorage.removeItem('tranoko_admin_access');
  }
}

