  header.innerHTML = `
    <div class="dph-section">
      <div class="dph-label">Émetteur</div>
      <div class="dph-val">${proSession?.nom || 'Tranoko'}</div>
      <div style="color:rgba(255,255,255,0.5);font-size:0.72rem;">${proSession?.tel || ''}</div>
    </div>
    <div class="dph-section">
      <div class="dph-label">Client</div>
      <div class="dph-val">${nomClient}</div>
      <div style="color:rgba(255,255,255,0.5);font-size:0.72rem;">${telClient}</div>
    </div>
    <div class="dph-section">
      <div class="dph-label">Référence</div>
      <div class="dph-num">${devisNum}</div>
    </div>
    <div class="dph-section">
      <div class="dph-label">Date</div>
      <div class="dph-val">${date}</div>
