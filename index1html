// vol_beton en m³, nb_sacs_mortier en sacs
function calcEau(vol_beton, nb_sacs_mortier) {
  const litres = (vol_beton * 185) + (nb_sacs_mortier * 15);
  const bidons = Math.ceil(litres / 20);
  return { litres: Math.round(litres), bidons, cout: bidons * P.eau_bidon.prix };
}

// ═══ CLOUS ═══
// surf_coffrage en m², nb_pieces_toiture
function calcClous(surf_coffrage, nb_pieces_toiture) {
  const kg30  = Math.ceil(surf_coffrage * 0.05);  // petits assemblages
  const kg50  = Math.ceil(surf_coffrage * 0.15);  // planches légères
  const kg70  = Math.ceil(surf_coffrage * 0.25);  // planches coffrage
  const kg100 = Math.ceil(surf_coffrage * 0.10 + (nb_pieces_toiture||0) * 0.02);
  const cout  = kg30*P.clou_30.prix + kg50*P.clou_50.prix + kg70*P.clou_70.prix + kg100*P.clou_100.prix;
  return { kg30, kg50, kg70, kg100, cout };
}


