// ═══ CODES — Validation & Génération via API sécurisée ═══
// Aucun secret dans le navigateur. Tout passe par /api/validate-code et /api/generate-code.

// Identifiant appareil stable (anonyme, stocké localStorage)
function getDeviceId() {
  let id = localStorage.getItem('tranoko_device_id');
  if (!id) {
    const arr = new Uint8Array(16);
    crypto.getRandomValues(arr);
    id = Array.from(arr).map(b => b.toString(16).padStart(2,'0')).join('');
    localStorage.setItem('tranoko_device_id', id);
  }
  return id;
}

// ── Appel API centralisé ──
async function apiCall(endpoint, data) {
  const res = await fetch(endpoint, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  return res.json();
}

// ── Messages d'erreur lisibles ──
function errMsg(reason) {
  const msgs = {
    format:                    '❌ Format invalide. Attendu : XXXX-XXXXXX',
    prefix:                    '❌ Préfixe de code inconnu.',
    type_mismatch:             '❌ Ce code ne correspond pas à ce module.',
    checksum:                  '❌ Code invalide.',
    not_found:                 '❌ Code introuvable.',
    revoked:                   '❌ Code révoqué par l\'administrateur.',
    already_used_other_device: '❌ Code déjà activé sur un autre appareil.',
    expired:                   '❌ Abonnement expiré. Renouvelez auprès de Tranoko.',
  };
  return msgs[reason] || '❌ Erreur inconnue.';
}

// ── Validation code débloquage (dalle/maison/cloture) ──
async function validateCode() {
  const input = v('code-input').value.trim().toUpperCase();
  const errEl = v('code-err'); const okEl = v('code-ok');
  errEl.style.display='none'; okEl.style.display='none';
  v('code-input').disabled = true;

  try {
    const result = await apiCall('/api/validate-code', {
      code: input,
      type: currentPayType,
      deviceId: getDeviceId()
    });
    if (result.valid) {
      okEl.textContent = '✅ Accès accordé !';
      okEl.style.display = 'block';
      setTimeout(() => { closePay(); unlockedTypes[currentPayType]=true; showResult(currentPayType); }, 1200);
    } else {
      errEl.textContent = errMsg(result.reason);
      errEl.style.display = 'block';
    }
  } catch {
    errEl.textContent = '❌ Erreur réseau. Vérifiez votre connexion.';
    errEl.style.display = 'block';
  } finally {
    v('code-input').disabled = false;
  }
}

// ── Génération code à l'acte (admin) ──
async function generateCode() {
  const type = v('code-type').value;
  const pass = v('admin-pass-cached');
  if (!pass) return;
  const btn = event.target; btn.disabled = true; btn.textContent = '⏳ Génération…';

  try {
    const result = await apiCall('/api/generate-code', {
      adminPassword: pass,
      type
    });
    if (result.code) {
      const codes = getCodes();
      codes.push({ code: result.code, type, date: new Date().toLocaleDateString('fr-MG') });
      saveCodes(codes); renderCodes();
      try { await navigator.clipboard.writeText(result.code); } catch {}
      alert('✅ Code généré et copié :\n' + result.code);
    } else {
      alert('❌ Erreur : ' + (result.error || 'inconnue'));
    }
  } catch { alert('❌ Erreur réseau.'); }
  finally { btn.disabled = false; btn.textContent = '➕ Générer code'; }
}

function getCodes() { try{ return JSON.parse(localStorage.getItem('tranoko_v2_codes')||'[]'); }catch{return[];} }
function saveCodes(c) { try{ localStorage.setItem('tranoko_v2_codes', JSON.stringify(c)); }catch{} }

function renderCodes() {
  const codes = getCodes();
  const el = v('codes-list');
  if(!codes.length){ el.innerHTML='<div style="color:#888;font-size:0.75rem;margin-top:6px;">Aucun code généré.</div>'; return; }
  el.innerHTML = codes.slice().reverse().map(c=>`
    <div class="code-item">
      <span class="code-val">${c.code}</span>
      <span style="font-size:0.72rem;color:#999;">${c.type}</span>
      <span class="code-st unused">Envoyé</span>
      <span style="font-size:0.65rem;color:#888;">${c.date}</span>
      <button onclick="copyCode('${c.code}')" style="background:#1A5276;color:white;border:none;padding:2px 8px;border-radius:5px;cursor:pointer;font-size:0.68rem;">📋 Copier</button>
    </div>`).join('');
}

function copyCode(code) {
  navigator.clipboard.writeText(code).then(()=>{
    alert('Code copié : ' + code + '\nEnvoyez-le au client par SMS ou Messenger.');
  }).catch(()=>{
    prompt('Copiez ce code et envoyez-le au client :', code);
  });
}

// ═══ ADMIN ═══
// Le mot de passe est envoyé au serveur — jamais stocké en clair ici.
let _adminPassCached = ''; // temporaire en mémoire, effacé si on recharge
function toggleAdmin() {
  const el = v('admin-login');
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
async function checkAdmin() {
  const pass = v('admin-pass').value;
  if (!pass) return;
  // Vérification via API (un appel de génération test)
  try {
    const res = await fetch('/api/generate-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ adminPassword: pass, type: '_check' })
    });
    // 403 = mauvais mdp, autre erreur = bon mdp mais type invalide = accès ok
    if (res.status === 403) {
      v('admin-err').style.display = 'block'; return;
    }
    _adminPassCached = pass;
    // Monkey-patch pour passer le mot de passe aux fonctions generate
    window['admin-pass-cached'] = { value: pass };
    v('admin-login').style.display = 'none';
    v('admin-section').style.display = 'block';
    buildAdminPrices(); renderCodes(); renderAbons();
    v('admin-err').style.display = 'none';
  } catch {
    v('admin-err').style.display = 'block';
  }
}

function buildAdminPrices() {
  Object.entries(ADMIN_GROUPS).forEach(([gid, keys]) => {
    const el = v(gid);
    if(!el) return;
    el.innerHTML = keys.map(k => P[k] ? `
      <div class="admin-item">
        <label>${P[k].label} (${P[k].unit})</label>
        <input type="number" id="ap_${k}" value="${P[k].prix}" min="0" step="100">
      </div>` : '').join('');
