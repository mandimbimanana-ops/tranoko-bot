function addPiece() {
  pieces.push({ type:'Chambre', lon:3, lar:3, portes:1, fenetres:1, sol:'30x30' });
  renderPieces(); onMaisonChange();
}

function setStanding(type, val) {
  if (type === 'sdb') {
    sdbStanding = val;
    ['eco','std','prem'].forEach(x => {
      const b = v('sdb-'+x);
      if(b) { b.classList.toggle('active', x===val); }
    });
    const dd = v('sdb-desc');
    if(dd){
      dd.textContent = SDB_DATA[val].desc;
      dd.className = 'standing-desc' + (val==='eco'?' eco-desc':val==='prem'?' prem-desc':'');
    }
  } else {
    cuiStanding = val;
    ['eco','std','prem'].forEach(x => {
      const b = v('cui-'+x);
      if(b) { b.classList.toggle('active', x===val); }
    });
    const dd = v('cui-desc');
    if(dd){
      dd.textContent = CUI_DATA[val].desc;
      dd.className = 'standing-desc' + (val==='eco'?' eco-desc':val==='prem'?' prem-desc':'');
    }
  }
  calcMaison();
}

