}

// ── Modal abonnement ──
function openSubModal() { v('modal-sub').classList.add('open'); }
function closeSubModal() { v('modal-sub').classList.remove('open'); }
let selectedPlan = 'annuel';
function selectPlan(plan) {
  selectedPlan = plan;
  v('plan-mensuel').classList.toggle('selected', plan==='mensuel');
  v('plan-annuel').classList.toggle('selected', plan==='annuel');
